import java.lang.Math;
class Solution {
    public int maxProfit(int[] prices) {
        int pro = 0, buy = 0;
        for(int i=1;i<prices.length;i++){
            if(prices[buy] > prices[i]){
                buy = i;
            }else {
                pro = Math.max(pro, prices[i]-prices[buy]);
            }
        }
        return pro;
    }
}
